# Security: use placeholders only. Never commit real keys.
NVIDIA_API_KEY=nvapi-REPLACE_ME

# Provider switch: local | nim
INFERENCE_PROVIDER=local

# Core contract
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=3
TELEMETRY_ENABLED=true
BENCHMARK_RUNS=10

# Paths
PDF_DIR=data/pdfs
CHROMA_PATH=data/chroma
CHROMA_COLLECTION=edge_rag_documents

# Embeddings: forced to CPU by implementation
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Local provider
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL_Q4=llama3.1:8b-instruct-q4_K_M
LOCAL_MODEL_Q8=llama3.1:8b-instruct-q8_0

# NIM provider
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_MODEL=meta/llama-3.1-8b-instruct

# Generation
MAX_TOKENS=512
TEMPERATURE=0.1
